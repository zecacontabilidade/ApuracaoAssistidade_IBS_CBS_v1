# =============================================================================
# frontend/.env.example — Variáveis de ambiente do frontend React/Vite
# =============================================================================
# INSTRUÇÕES:
#   1. Copie para frontend/.env.local (nunca commite o arquivo real)
#   2. No devcontainer, o Vite expõe apenas vars prefixadas com VITE_
#   3. NUNCA coloque segredos aqui — o bundle do Vite é público
# =============================================================================

# --- Ambiente -----------------------------------------------------------------
# Valores: development | production | staging
VITE_ENV=development

# --- API Backend (F1.0+) -----------------------------------------------------
# URL base da API FastAPI. No devcontainer use http://localhost:8000
# Em produção: https://api.seudominio.com.br
# Sem trailing slash.
VITE_API_BASE_URL=http://localhost:8000

# NOTA: GEMINI_API_KEY foi removida do frontend e movida para o backend (F1.10).
# Não adicione segredos aqui — eles ficam visíveis no bundle JavaScript.
