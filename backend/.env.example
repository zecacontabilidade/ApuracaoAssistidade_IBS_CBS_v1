# =============================================================================
# backend/.env.example — Variáveis de ambiente do backend FastAPI
# =============================================================================
# INSTRUCOES:
#   1. Copie este arquivo para backend/.env   (nunca commite o .env real)
#   2. Substitua os placeholders pelos valores reais (dev ou prod)
#   3. Em produção: use AWS Secrets Manager; NÃO coloque segredos em arquivos.
# =============================================================================

# --- Banco de dados -----------------------------------------------------------
# Driver psycopg3 (SQLAlchemy 2.0 async). No devcontainer o host é "db".
DATABASE_URL=postgresql+psycopg://app:app@db:5432/apuracao

# --- Fila assíncrona (Dramatiq + Redis) — ADR 0005 ---------------------------
REDIS_URL=redis://redis:6379/0

# --- Object storage (MinIO no dev, S3 em prod) --------------------------------
# No devcontainer o host é "minio" (serviço compose). Em prod: URL da região AWS.
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=xml-raw

# --- Autenticação JWT (fastapi-users + argon2) — ADR 0002 --------------------
# OBRIGATORIO: gere um segredo forte em prod (ex.: openssl rand -hex 32)
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# Duração dos tokens (segundos)
ACCESS_TOKEN_TTL=900        # 15 min
REFRESH_TOKEN_TTL=604800    # 7 dias

# --- IA (Gemini) — processamento server-side de XMLs -------------------------
# Obtenha em: https://aistudio.google.com/app/apikey
# Deixe vazio para desativar chamadas à IA durante o desenvolvimento.
GEMINI_API_KEY=

# --- Ambiente -----------------------------------------------------------------
ENVIRONMENT=development
# Outros valores válidos: production, staging, test
